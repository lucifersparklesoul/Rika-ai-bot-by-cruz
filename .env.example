TELEGRAM_TOKEN=your-telegram-bot-token
OPENAI_API_KEY=your-openai-api-key
BOT_ADMIN_IDS=123456789 # comma-separated telegram user IDs
DB_PATH=./data/bot.db
SYSTEM_PROMPT=You are a helpful, friendly, and concise AI assistant for Telegram users.
TEMPERATURE=0.2
OPENAI_CHAT_MODEL=gpt-3.5-turbo
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# For Railway deployment: the public HTTPS URL Railway provides for your project, e.g. https://project-xyz.up.railway.app
WEBHOOK_URL=
# Railway will provide PORT automatically; you can set a default locally
PORT=8000
